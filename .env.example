# Staging server (blackpearl) -- copy to .env and fill secrets. Never commit .env.

STAGING_HOST=blackpearl
STAGING_USER=s4il0r
# Private key path on this PC (OpenSSH format)
STAGING_KEY=C:\Users\Julian\Documents\Programming\beelink-cleanup\blackpearl

# Optional: only needed if passwordless sudo was NOT configured (fresh install uses NOPASSWD)
# STAGING_PASSWORD=

# GitHub fine-grained PAT for push/clone (cap-jmk-launchpad/homelab-k3s -- Contents read/write).
# Create at https://github.com/settings/tokens then paste into .env (never commit).
GH_TOKEN=

# Push with token: bash scripts/git-push.sh
# Or: source scripts/lib/load-env.sh && git -c "http.extraHeader=Authorization: Bearer ${GH_TOKEN}" push origin master:main

# SSH one-liner (after fresh install + setup-blackpearl-access.sh):
# ssh -i %STAGING_KEY% %STAGING_USER%@%STAGING_HOST%

# blackpearl roles: SSH/admin 192.168.10.41, k3s edge (Fritz port-forward) 192.168.10.33

# HCP Vault (bootstrap CLI only — never commit tokens)
# Public cluster URL from HCP portal → Vault → your cluster → Public cluster URL
VAULT_ADDR=https://YOUR-CLUSTER.vault.xxxxx.hashicorp.cloud:8200
VAULT_NAMESPACE=admin
# One-time admin token from HCP portal (rotate after bootstrap)
# VAULT_TOKEN=

# Optional: HCP service principal for vault login without admin token
# HCP_CLIENT_ID=
# HCP_CLIENT_SECRET=