# Staging server (blackpearl) -- copy to .env and fill secrets. Never commit .env.

STAGING_HOST=blackpearl
# k3s InternalIP on blackpearl (must exist on NIC — see scripts/homelab-blackpearl-node-ip-fix.sh)
K3S_NODE_IP=192.168.10.33
# DHCP address on enp1s0 (may differ from K3S_NODE_IP)
BLACKPEARL_DHCP_IP=192.168.10.41
STAGING_USER=s4il0r
# Private key path on this PC (OpenSSH format)
STAGING_KEY=C:\Users\Julian\Documents\Programming\beelink-cleanup\blackpearl

# Optional: only needed if passwordless sudo was NOT configured (fresh install uses NOPASSWD)
# STAGING_PASSWORD=

# GitHub fine-grained PAT for push/clone (cap-jmk-launchpad/homelab-k3s -- Contents read/write).
# Create at https://github.com/settings/tokens then paste into .env (never commit).
GH_TOKEN=

# Push with token: bash scripts/git-push.sh
# Or: source scripts/lib/load-env.sh && git -c "http.extraHeader=Authorization: Bearer ${GH_TOKEN}" push origin master:main

# SSH one-liner (after fresh install + setup-blackpearl-access.sh):
# ssh -i %STAGING_KEY% %STAGING_USER%@%STAGING_HOST%

# blackpearl roles: SSH/admin 192.168.10.41, k3s edge (Fritz port-forward) 192.168.10.33

# HCP Vault (bootstrap CLI only — never commit tokens)
# Public cluster URL from HCP portal → Vault → your cluster → Public cluster URL
VAULT_ADDR=https://YOUR-CLUSTER.vault.xxxxx.hashicorp.cloud:8200
VAULT_NAMESPACE=admin
# One-time admin token from HCP portal (rotate after bootstrap)
# VAULT_TOKEN=

# Optional: HCP service principal for vault login without admin token
# HCP_CLIENT_ID=
# HCP_CLIENT_SECRET=

# Launchpad Supabase (see docs/supabase-launchpad.md) — prefer launchpad/.env as source of truth
# LAUNCHPAD_ENV=../.env
# SUPABASE_REGENERATE_SECRETS=1
# SUPABASE_NAMESPACE=supabase
# POSTGRES_PASSWORD=
# JWT_SECRET=
# ANON_KEY=
# SERVICE_ROLE_KEY=
# DASHBOARD_USERNAME=
# DASHBOARD_PASSWORD=

# GitLab CE (see docs/gitlab-homelab.md) — prefer launchpad/.env as source of truth
# GITLAB_REGENERATE_SECRETS=1
# GITLAB_NAMESPACE=gitlab
# GITLAB_NODEPORT=30481
# GITLAB_EXTERNAL_URL=http://127.0.0.1:30481
# GITLAB_URL=http://gitlab.gitlab.svc.cluster.local
# GITLAB_PUBLIC_URL=
# GITLAB_ROOT_PASSWORD=
# GITLAB_RUNNER_REGISTRATION_TOKEN=
# GITLAB_REGISTRY_ENABLED=0

# MITRE CWE mirror (see docs/cwe-homelab.md) — prefer launchpad/.env as source of truth
# CWE_REGENERATE_SECRETS=1
# CWE_NAMESPACE=cwe
# CWE_NODEPORT=30483
# CWE_PUBLIC_URL=
# CWE_SOURCE_URL=https://cwe.mitre.org/data/xml/cwec_latest.xml.zip
# CWE_SYNC_SCHEDULE=*/10 * * * *
# CWE_MIRROR_API_TOKEN=

# Internal CA / step-ca (see docs/internal-ca-homelab.md) — prefer launchpad/.env
# STEP_CA_REGENERATE_SECRETS=1
# STEP_CA_NAMESPACE=step-ca
# STEP_CA_NODEPORT=30484
# STEP_CA_DNS=ca.homelab.lan,pki.homelab.lan
# STEP_CA_ACME_URL=https://ca.homelab.lan/acme/acme/directory
# STEP_CA_PASSWORD=
# STEP_PROVISIONER_PASSWORD=

# OWASP Dependency-Track (see docs/dependency-track-homelab.md) — prefer launchpad/.env
# DEPTRACK_URL=
# DEPTRACK_API_BASE_URL=
# DEPTRACK_ADMIN_USER=admin
# DEPTRACK_ADMIN_PASSWORD=
# DEPTRACK_REGENERATE_SECRETS=1
# DEPTRACK_REGENERATE_API_KEY=1
# DEPTRACK_NAMESPACE=dependency-track
# DEPTRACK_NODEPORT=30482
# DEPTRACK_PUBLIC_URL=
# DEPTRACK_POSTGRES_PASSWORD=
# DEPTRACK_ALPINE_SECRET_KEY=
# DEPTRACK_MIRROR_CADENCE_HOURS=1
# DEPTRACK_API_KEY=