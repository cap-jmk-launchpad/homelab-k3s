[Unit]
Description=li-httpd homelab edge (LIS ingress)
After=network-online.target k3s.service
Wants=network-online.target
# Render: edge-lis-apply.sh holds /run/li-httpd/edge-apply.lock (safe parallel restarts).

[Service]
Type=simple
Environment=LIC_ROOT=/home/s4il0r/staging/lic
Environment=LI_HTTPD_ROOT=/home/s4il0r/staging/li-httpd
Environment=MAJICO_HTTPD_TOML=/home/s4il0r/staging/majico-deploy/deploy/staging/edge/majico-staging.httpd.toml
ExecStartPre=/bin/mkdir -p /run/li-httpd /var/lib/li-httpd/empty
ExecStartPre=/bin/bash -c 'HOME=/home/s4il0r LIC_ROOT=/home/s4il0r/staging/lic LI_HTTPD_ROOT=/home/s4il0r/staging/li-httpd MAJICO_HTTPD_TOML=/home/s4il0r/staging/majico-deploy/deploy/staging/edge/majico-staging.httpd.toml bash /home/s4il0r/staging/homelab-k3s/scripts/edge-lis-apply.sh --render-only'
ExecStart=/usr/local/bin/li-httpd /run/li-httpd/homelab.runtime.conf
User=root
Group=root
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
