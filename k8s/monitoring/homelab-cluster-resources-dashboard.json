          "instant": true,
          "legendFormat": "",
          "refId": "cpu"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * on(instance) group_left(node) label_replace(kube_node_info, \"instance\", \"$1:9100\", \"internal_ip\", \"(.*)\")",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "mempct"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1024^3) * on(instance) group_left(node) label_replace(kube_node_info, \"instance\", \"$1:9100\", \"internal_ip\", \"(.*)\")",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "memused"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(node_memory_MemTotal_bytes / 1024^3) * on(instance) group_left(node) label_replace(kube_node_info, \"instance\", \"$1:9100\", \"internal_ip\", \"(.*)\")",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "memtotal"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum by (instance) (rate(node_network_receive_bytes_total{device!~\"lo|veth.*|cali.*|flannel.*|docker.*|br-.*\"}[5m])) * 8) * on(instance) group_left(node) label_replace(kube_node_info, \"instance\", \"$1:9100\", \"internal_ip\", \"(.*)\")",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "rx"
        },
        {
          "datasource": {
